[Unit]
Description=Rock 3C WiFi-check og AP-fallback
After=network.target
Wants=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/wifi-check.sh
RemainAfterExit=yes
StandardOutput=append:/var/log/wifi-check.log
StandardError=append:/var/log/wifi-check.log

[Install]
WantedBy=multi-user.target
